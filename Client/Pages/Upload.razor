@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@using System.Text
@inject HttpClient http

<div class="upload-card">
    <div class="form-grid">
        <div class="field">
            <label for="container">Container name</label>
            <input id="container" placeholder="e.g. my-collection" @bind="containerName" @bind:event="oninput" disabled="@isUploading" />
            <small class="hint">Lowercase, no spaces. Will be used as the blob container name.</small>
            @if (showContainerValidation)
            {
                <div class="validation">Container name is required and may contain only letters, numbers, hyphens and underscores.</div>
            }
        </div>

        <div class="field fullwidth">
            <label for="description">Description (optional)</label>
            <textarea id="description" rows="4" placeholder="Short description shown on the overview" @bind="description" disabled="@isUploading"></textarea>
        </div>

        <div class="field">
            <label>Cover image</label>
            <InputFile OnChange="OnCoverSelectedAsync" accept="image/*" disabled="@isUploading" />
            @if (!string.IsNullOrEmpty(coverName))
            {
                <div class="file-meta">Selected: @coverName</div>
            }
            @if (!string.IsNullOrEmpty(coverPreview))
            {
                <div class="preview">
                    <img src="@coverPreview" alt="Cover preview" />
                </div>
            }
        </div>

        <div class="field">
            <label>Other images</label>
            <InputFile OnChange="OnImagesSelectedAsync" multiple accept="image/*" disabled="@isUploading" />
            @if (imageNames?.Any() == true)
            {
                <div class="file-meta">Selected: @imageNames.Count image(s)</div>
                <div class="preview-grid">
                    @for (int i = 0; i < otherPreviews.Count; i++)
                    {
                        <div class="thumb" title="@imageNames[i]">
                            <img src="@otherPreviews[i]" alt="@imageNames[i]" />
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="actions">
        <button type="button" class="primary" @onclick="UploadCollection" disabled="@(isUploading || isInvalid)">
            @if (isUploading)
            {
                <i class="fas fa-spinner fa-spin" aria-hidden="true"></i>
                <span class="sr-only">Uploading...</span>
            }
            Upload
        </button>
        <button type="button" class="secondary" @onclick="Cancel" disabled="@isUploading">Cancel</button>
    </div>

    @if (!string.IsNullOrEmpty(status))
    {
        <div class="status">@status</div>
    }
</div>

@code {
    private const long MaxFileSize = 20 * 1024 * 1024; // 20 MB per file

    // auth
    [Parameter]
    public string UploadPassword { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public EventCallback OnUploaded { get; set; }

    // upload form
    private string containerName;
    private string description;
    private IBrowserFile coverFile;
    private List<IBrowserFile> otherFiles = new();
    private string coverName;
    private List<string> imageNames = new();
    private bool isUploading;
    private string status;

    // UI-only previews
    private string coverPreview;
    private List<string> otherPreviews = new();

    private bool attemptedSubmit;
    private bool isInvalid => string.IsNullOrWhiteSpace(containerName) || !IsValidContainerName(containerName);
    private bool showContainerValidation => attemptedSubmit && isInvalid;

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync(null);
        }
    }

    private static bool IsValidContainerName(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return false;
        // allow letters, numbers, hyphens and underscores (case-insensitive)
        return System.Text.RegularExpressions.Regex.IsMatch(name.Trim(), @"^[a-z0-9\-_]+$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
    }

    private async Task OnCoverSelectedAsync(InputFileChangeEventArgs e)
    {
        coverFile = e.File;
        coverName = coverFile?.Name;
        coverPreview = await GetImagePreviewDataUrlAsync(coverFile);
        StateHasChanged();
    }

    private async Task OnImagesSelectedAsync(InputFileChangeEventArgs e)
    {
        otherFiles = e.GetMultipleFiles().ToList();
        imageNames = otherFiles.Select(f => f.Name).ToList();

        otherPreviews.Clear();
        foreach (var f in otherFiles)
        {
            otherPreviews.Add(await GetImagePreviewDataUrlAsync(f));
        }

        StateHasChanged();
    }

    private async Task<string> GetImagePreviewDataUrlAsync(IBrowserFile file)
    {
        if (file == null) return null;

        try
        {
            // Request a smaller image for preview to save memory and bandwidth in the browser
            var format = "image/png";
            var maxWidth = 400;
            var maxHeight = 300;
            var imageFile = await file.RequestImageFileAsync(format, maxWidth, maxHeight);
            using var ms = new MemoryStream();
            await imageFile.OpenReadStream(MaxFileSize).CopyToAsync(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            return $"data:{format};base64,{b64}";
        }
        catch
        {
            // fallback: read raw file
            using var ms = new MemoryStream();
            await file.OpenReadStream(MaxFileSize).CopyToAsync(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            return $"data:{file.ContentType};base64,{b64}";
        }
    }

    private async Task<string> ReadFileAsBase64(IBrowserFile file)
    {
        if (file == null) return null;

        using var ms = new MemoryStream();
        var stream = file.OpenReadStream(MaxFileSize);
        await stream.CopyToAsync(ms);
        return Convert.ToBase64String(ms.ToArray());
    }

    private async Task UploadCollection()
    {
        attemptedSubmit = true;

        if (isInvalid)
        {
            status = "Please provide a valid container name.";
            return;
        }

        isUploading = true;
        status = "Preparing files...";

        try
        {
            var coverBase64 = await ReadFileAsBase64(coverFile);

            var imageDtos = new List<object>();
            foreach (var f in otherFiles)
            {
                var b64 = await ReadFileAsBase64(f);
                imageDtos.Add(new { FileName = f.Name, Base64 = b64 });
            }

            var payload = new
            {
                ContainerName = containerName.Trim().ToLowerInvariant(),
                Description = description ?? string.Empty,
                CoverFileName = coverFile?.Name,
                CoverBase64 = coverBase64,
                Images = imageDtos
            };

            var json = JsonSerializer.Serialize(payload);
            using var content = new StringContent(json, Encoding.UTF8, "application/json");
            using var request = new HttpRequestMessage(HttpMethod.Post, "api/upload-collection");
            request.Content = content;
            // include password header so server enforces it on upload
            request.Headers.Add("X-Upload-Password", UploadPassword);

            var resp = await http.SendAsync(request);

            if (resp.IsSuccessStatusCode)
            {
                status = "Upload successful. Reloading overview...";
                if (OnUploaded.HasDelegate)
                {
                    await OnUploaded.InvokeAsync(null);
                }
            }
            else
            {
                var text = await resp.Content.ReadAsStringAsync();
                status = $"Upload failed: {resp.StatusCode} - {text}";
            }
        }
        catch (Exception ex)
        {
            status = $"Error: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }
}