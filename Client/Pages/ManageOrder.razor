@page "/manage-order"
@inject HttpClient http
@inject NavigationManager navigation
@inject IJSRuntime js

<h3 class="title">Manage collection order</h3>

@if (!isUnlocked)
{
    <UnlockCard Label="Enter manage password" OnUnlocked="HandleUnlock" OnCancel="NavigateToOverview" />
}
else
{
        @if (summaries == null)
        {
            <p>Loading...</p>
        }
        else if (!summaries.Any())
        {
            <p>No collections found.</p>
        }
        else
        {
            <div class="manage-list">
                @for (int i = 0; i < summaries.Count; i++)
                {
                    var item = summaries[i];
                    var index = i;
                    <div class="manage-item">
                        <div class="thumb">
                            @if (!string.IsNullOrEmpty(item.CoverImageUri))
                            {
                                <img src="@item.CoverImageUri" alt="@item.ContainerName" />
                            }
                        </div>
                        <div class="meta">
                            <div class="name">@item.ContainerName</div>
                            <div class="desc">@item.Description</div>
                        </div>
                        <div class="controls">
                            <button type="button" class="secondary small" @onclick="() => MoveUp(index)" disabled="@(index == 0)">▲</button>
                            <button type="button" class="secondary small" @onclick="() => MoveDown(index)" disabled="@(index == summaries.Count - 1)">▼</button>
                            <button type="button" class="danger small" @onclick="() => DeleteCollection(index)">🗑</button>
                        </div>
                    </div>
                }
            </div>

            <div class="actions" style="margin-top:1rem">
                <button class="primary" @onclick="Save" disabled="@(isSaving)">Save order</button>
                <button class="secondary" @onclick="NavigateToOverview">Cancel</button>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="status">@statusMessage</div>
            }
        }
}

@code {
    private List<Data.ImageCollectionSummary> summaries;
    private string statusMessage;
    private bool isSaving;

    // password/unlock
    private string uploadPassword;
    private bool isUnlocked;

    protected override async Task OnInitializedAsync()
    {
        summaries = await http.GetFromJsonAsync<List<Data.ImageCollectionSummary>>("api/ImageCollectionSummaries");
    }

    private void MoveUp(int index)
    {
        if (index <= 0) return;
        var item = summaries[index];
        summaries.RemoveAt(index);
        summaries.Insert(index - 1, item);
        StateHasChanged();
    }

    private void MoveDown(int index)
    {
        if (index >= summaries.Count - 1) return;
        var item = summaries[index];
        summaries.RemoveAt(index);
        summaries.Insert(index + 1, item);
        StateHasChanged();
    }

    private void HandleUnlock(string password)
    {
        uploadPassword = password;
        isUnlocked = true;
        statusMessage = null;
    }

    private async Task DeleteCollection(int index)
    {
        if (!isUnlocked)
        {
            statusMessage = "Unlock first.";
            return;
        }

        var name = summaries[index].ContainerName;
        var confirmed = await js.InvokeAsync<bool>("confirm", $"Delete collection '{name}'? This will remove the entire container and its blobs.");
        if (!confirmed) return;

        statusMessage = "Deleting...";
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Delete, $"api/collections/{Uri.EscapeDataString(name)}");
            request.Headers.Add("X-Upload-Password", uploadPassword);

            var resp = await http.SendAsync(request);

            if (resp.IsSuccessStatusCode)
            {
                summaries.RemoveAt(index);
                statusMessage = $"Deleted '{name}'.";
                StateHasChanged();
            }
            else
            {
                var text = await resp.Content.ReadAsStringAsync();
                statusMessage = $"Delete failed: {resp.StatusCode} - {text}";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error deleting: {ex.Message}";
        }
    }

    private async Task Save()
    {
        if (!isUnlocked)
        {
            statusMessage = "Unlock first.";
            return;
        }

        isSaving = true;
        statusMessage = "Saving...";
        StateHasChanged();

        var order = summaries.Select(s => s.ContainerName).ToList();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, "api/collections/order")
            {
                Content = JsonContent.Create(order)
            };
            request.Headers.Add("X-Upload-Password", uploadPassword);

            var response = await http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Order saved.";
                await Task.Delay(350);
                navigation.NavigateTo("/overview", true);
            }
            else
            {
                statusMessage = $"Failed to save: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error saving order: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void NavigateToOverview()
    {
        navigation.NavigateTo("/overview");
    }
}